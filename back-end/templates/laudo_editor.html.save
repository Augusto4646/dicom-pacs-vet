        <!DOCTYPE html>
        <html>
        <head>
        <meta charset="UTF-8">
        <title>Laudo</title>

        <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

        <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
        <style>

        body{
        margin:0;
        font-family:Arial;
        height:100vh;
        overflow:hidden;
        background:#f5f5f5;
        }

        .container{
        display:flex;
        height:100vh;
        }

        .viewer{
        width:50%;
        background:black;
        }

        .viewer iframe{
        width:100%;
        height:100%;
        border:none;
        }

        .resizer{
        width:5px;
        background:#cfcfcf;
        cursor:col-resize;
        }

        .editor{
        flex:1;
        display:flex;
        flex-direction:column;
        padding:20px;
        border-left:1px solid #ddd;
        background:#fafafa;
        }

        .title{
        font-size:20px;
        font-weight:bold;
        margin-bottom:10px;
        }

        .controls{
        display:flex;
        gap:8px;
        margin-bottom:10px;
        flex-wrap:wrap;
        }

        .controls select{
        padding:6px;
        border-radius:4px;
        border:1px solid #ccc;
        }

        .statusbar{
        display:flex;
        justify-content:space-between;
        font-size:13px;
        color:#555;
        margin-bottom:10px;
        }

        #editor{
        flex:1;
        background:white;
        }

        .ql-container{
        height:100%;
        }

        .ql-editor{
        font-size:16px;
        }

        .ql-editor img{
        max-width:100%;
        height:auto;
        margin:10px 0;
        border-radius:6px;
        }

        /* BOTÕES */

        button{
        padding:8px 12px;
        border:none;
        border-radius:6px;
        cursor:pointer;
        font-size:14px;
        display:flex;
        align-items:center;
        gap:4px;
        }

        button:hover{
        opacity:0.9;
        }

        .btn-salvar{background:#2ecc71;}
        .btn-pdf{background:#e74c3c;}
        .btn-html{background:#9b59b6;}
        .btn-texto{background:#f39c12;}
        .btn-modelo{background:#1abc9c;}
        .btn-limpar{background:#7f8c8d;}
        .btn-img{background:#34495e;}

        .actions{
        margin-top:10px;
        display:flex;
        flex-wrap:wrap;
        gap:6px;
        }

        </style>
        </head>

        <body>

        <div class="container">

        <div class="viewer" id="viewer">

     <iframe 
          src="/viewer/viewer/dicomweb?StudyInstanceUIDs={{ exame.study_instance_uid }}">
  </iframe>

        </div>

        <div class="resizer" id="resizer"></div>

        <div class="editor">

        <div class="title">Laudo Radiográfico</div>

        <div class="controls">

        <label>Tamanho:</label>

        <select id="fontSize">
        <option value="12px">12</option>
        <option value="14px">14</option>
        <option value="16px" selected>16</option>
        <option value="18px">18</option>
        <option value="24px">24</option>
        <option value="32px">32</option>
        </select>

        <button onclick="setSize()">🔠 Aplicar</button>

        <button class="btn-pdf" onclick="gerarPDF()">📄 PDF</button>

        </div>

        <div class="statusbar">
        <div id="status">Não salvo</div>
        <div id="contador">0 palavras</div>
        </div>

        <div id="editor"></div>

        <div class="actions">

        <button class="btn-salvar" onclick="salvar()">💾 Salvar</button>

        <button class="btn-html" onclick="copiarHTML()">📋 HTML</button>

        <button class="btn-texto" onclick="copiarTexto()">📝 Texto</button>

        <button class="btn-modelo" onclick="modelo()">📑 Modelo</button>

        <button class="btn-limp
