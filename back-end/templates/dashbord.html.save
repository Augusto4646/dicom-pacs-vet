{% load static %}

<!DOCTYPE html>
<html>
<head>
<title>Dashboard</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<div class="container mt-5">

<h2 class="mb-4">Gerenciamente de Laudos</h2>

<a href="{% url 'sync_exames' %}" class="btn btn-success mb-3">
Sincronizar exames
</a>

<table class="table table-striped">

<thead>
<tr>
<th>Paciente</th>
<th>Descrição</th>
<th>Data</th>
<th>Status</th>
<th>Ações</th>
</tr>
</thead>

<tbody>

{% for exame in exames %}

<tr>

<td>{{ exame.paciente.nome }}</td>

<td>{{ exame.descricao }}</td>

<td>{{ exame.study_date }}</td>

<td>
{% if exame.status == "recebido" %}
<span class="badge bg-warning text-dark">Recebido</span>
{% else %}
<span class="badge bg-success">Laudado</span>
{% endif %}
</td>

<td>

<!-- BOTÃO ABRIR -->
<a href="{% url 'laudo_editor' exame.id %}" class="btn btn-primary btn-sm">
Abrir
</a>

<!-- FORM EDITAR -->
<a href="http://vizionvet.com.br/orthanc/ui/app/#/#study?uuid={{ exame.orthanc_id }}" target="_blank" class="btn btn-warning btn-sm">
Editar
</a>
<a href="{% url 'baixar_dicom' exame.id %}"class="btn btn-primary btn-sm">
    Baixar DICOM
</a>
</td>

</tr>

{% endfor %}

</tbody>

</table>

</div>

</body>
</html>
