{
  "Name": "Orthanc",
  "StorageDirectory": "/var/lib/orthanc/db",
  "IndexDirectory": "/var/lib/orthanc/db",

  "AuthenticationEnabled": false,
  "RemoteAccessAllowed": true,

  "MaximumStorageSize": 0,
  "MaximumPatientCount": 0,

  "HttpServer": {
    "Forwarded": true
  },

  "DicomWeb": {
    "Enable": true,
    "Root": "/dicom-web/"
  },

  "OrthancExplorer2": {
    "Enable": true,
    "IsDefaultOrthancUI": true
  },

  "WebHooks": {
    "Enable": true,
    "Hooks": [
      {
        "Url": "https://vizionxvet.conexao46.com/webhook/novo-exame/",
        "Events": ["NewInstance"]
      }
    ]
  }
}

